@{
    ViewData["Title"] = "Find Customer";
}

<h1>Find Customer</h1>

<h4>Search by AFM</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="FindCustomer" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label class="control-label">AFM</label>
                <input name="afm" class="form-control" />
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Search" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to Staff Panel</a>
</div>
