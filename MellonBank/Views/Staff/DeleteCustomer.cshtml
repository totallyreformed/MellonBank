@model MellonBank.Areas.Identity.Data.AppUser

@{
    ViewData["Title"] = "Delete Customer";
}

<h1>Delete Customer</h1>

<h3>Are you sure you want to delete this customer?</h3>
<div>
    <h4>Customer</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>
        <dt class="col-sm-2">Last Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.LastName)</dd>
        <dt class="col-sm-2">AFM</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AFM)</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Email)</dd>
        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.PhoneNumber)</dd>
        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Address)</dd>
    </dl>

    <form asp-action="DeleteCustomer" asp-route-afm="@Model.AFM">
        <input type="hidden" name="afm" value="@Model.AFM" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Customers">Back to Customers</a>
    </form>
</div>
